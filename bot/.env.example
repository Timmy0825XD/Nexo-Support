# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Dev guild — registers slash commands instantly (recommended for local dev)
DISCORD_GUILD_ID=

# Supabase (runtime — bot uses service role, server-side only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Prisma migrations — copy to prisma/.env (not used at bot runtime)
# DATABASE_URL=
# DIRECT_URL=

# Optional: encryption key for Challonge API keys stored in DB (32-byte hex)
CHALLONGE_KEY_ENCRYPTION_SECRET=

# Google Sheet — banned in-game player IDs (used by /sheet validate)
BANNED_PLAYERS_SHEET_URL=https://docs.google.com/spreadsheets/d/17Xv8rF_UmKslmd_MBGiBf610xb2YleQJHivoc-6JqYU/edit?usp=drive_link
