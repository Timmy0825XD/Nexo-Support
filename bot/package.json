{
  "name": "nexo-support-bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "commands:sync": "bun run src/scripts/sync-commands.ts",
    "commands:clear": "bun run src/scripts/sync-commands.ts --clear",
    "db:migrate": "prisma migrate deploy --schema ../prisma/schema.prisma",
    "db:push": "prisma db push --schema ../prisma/schema.prisma --skip-generate",
    "db:generate": "prisma generate --schema ../prisma/schema.prisma"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "discord-html-transcripts": "^3.3.0",
    "discord.js": "^14.21.0",
    "dotenv": "^16.5.0",
    "exceljs": "^4.4.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "prisma": "^6.9.0",
    "typescript": "^5.8.3"
  }
}
